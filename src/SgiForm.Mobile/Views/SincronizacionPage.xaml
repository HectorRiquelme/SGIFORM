<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SgiForm.Mobile.Views.SincronizacionPage"
             Title="Sincronización"
             BackgroundColor="#f3f4f6">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Operador info -->
            <Frame BackgroundColor="White" Padding="16" CornerRadius="12"
                   BorderColor="Transparent" HasShadow="True">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding NombreOperador}"
                           FontSize="18" FontAttributes="Bold" TextColor="#1f2937" />
                    <Label Text="{Binding EmpresaSlug}"
                           FontSize="13" TextColor="#6b7280" />
                </VerticalStackLayout>
            </Frame>

            <!-- Estado de conexión -->
            <Frame BackgroundColor="{Binding TieneConexion, Converter={StaticResource BoolToColorConverter}}"
                   Padding="12" CornerRadius="8" BorderColor="Transparent">
                <Label Text="{Binding TieneConexion, Converter={StaticResource BoolToConexionConverter}}"
                       TextColor="White" FontSize="14" FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <!-- Última sincronización -->
            <Frame BackgroundColor="White" Padding="16" CornerRadius="12"
                   BorderColor="Transparent" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Última sincronización" FontSize="13" TextColor="#6b7280" />
                    <Label Text="{Binding UltimaSyncTexto}"
                           FontSize="15" FontAttributes="Bold" TextColor="#1f2937" />
                </VerticalStackLayout>
            </Frame>

            <!-- Pendientes -->
            <Frame BackgroundColor="White" Padding="16" CornerRadius="12"
                   BorderColor="Transparent" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Pendientes de sincronizar" FontSize="13" TextColor="#6b7280" />
                    <Label Text="{Binding PendientesSync, StringFormat='{0} elementos'}"
                           FontSize="15" FontAttributes="Bold" TextColor="#1f2937" />
                </VerticalStackLayout>
            </Frame>

            <!-- Mensaje de sync -->
            <Label Text="{Binding MensajeSync}" FontSize="13" TextColor="#4b5563"
                   IsVisible="{Binding MensajeSync, Converter={StaticResource StringNotNullConverter}}" />

            <!-- Botón sincronizar -->
            <Button Text="{Binding Sincronizando, Converter={StaticResource BoolToSyncTextConverter}}"
                    Command="{Binding SincronizarCommand}"
                    IsEnabled="{Binding Sincronizando, Converter={StaticResource InvertBoolConverter}}"
                    BackgroundColor="#1a56db" TextColor="White"
                    FontAttributes="Bold" CornerRadius="8" HeightRequest="48" />

            <!-- Separador -->
            <BoxView HeightRequest="1" Color="#e5e7eb" Margin="0,8" />

            <!-- Botón cerrar sesión -->
            <Button Text="Cerrar sesión"
                    Command="{Binding CerrarSesionCommand}"
                    BackgroundColor="#e02424" TextColor="White"
                    FontAttributes="Bold" CornerRadius="8" HeightRequest="48" />

            <Label Text="{Binding AppVersion}" FontSize="11" TextColor="#9ca3af"
                   HorizontalTextAlignment="Center" />

            <Button Text="Ver notas de versión"
                    Command="{Binding VerNotasVersionCommand}"
                    BackgroundColor="#ffffff"
                    BorderColor="#d1d5db"
                    BorderWidth="1"
                    TextColor="#1f2937"
                    CornerRadius="8"
                    HeightRequest="44" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
