@page "/usuarios"
@layout SgiForm.Web.Components.Layout.MainLayout
@inject ApiClient Api

<PageTitle>Usuarios — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Usuarios</h2>
        <span class="sf-text-muted">Gestión de usuarios del sistema web</span>
    </div>
    <button class="sf-btn sf-btn-primary" @onclick="AbrirNuevo">+ Nuevo usuario</button>
</div>

@if (loading)
{
    <div class="sf-loading-center"><div class="sf-spinner"></div></div>
}
else
{
    <div class="sf-card">
        <table class="sf-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Último acceso</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in items)
                {
                    <tr>
                        <td>
                            <strong>@u.NombreCompleto</strong>
                            <div class="sf-text-muted sf-text-xs">@u.Telefono</div>
                        </td>
                        <td>@u.Email</td>
                        <td><span class="sf-badge sf-badge-info">@u.Rol?.Nombre</span></td>
                        <td>
                            @if (u.Estado == "activo")
                            { <span class="sf-badge sf-badge-success">Activo</span> }
                            else
                            { <span class="sf-badge sf-badge-danger">@u.Estado</span> }
                        </td>
                        <td class="sf-text-xs sf-text-muted">
                            @(u.UltimoAcceso.HasValue
                                ? u.UltimoAcceso.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                : "Nunca")
                        </td>
                        <td>
                            <div class="sf-action-btns">
                                <button class="sf-btn sf-btn-secondary sf-btn-sm"
                                        @onclick="() => AbrirEditar(u)">Editar</button>
                                <button class="sf-btn sf-btn-danger sf-btn-sm"
                                        @onclick="() => Eliminar(u.Id)">Eliminar</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!items.Any())
                {
                    <tr>
                        <td colspan="6" class="sf-text-center sf-text-muted" style="padding:32px">
                            Sin usuarios registrados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (mostrarModal)
{
    <div class="sf-modal-overlay">
        <div class="sf-modal">
            <div class="sf-modal-header">
                <h3>@(editando != null ? "Editar usuario" : "Nuevo usuario")</h3>
                <button class="sf-btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="sf-modal-body">
                @if (!string.IsNullOrEmpty(formError))
                { <div class="sf-alert sf-alert-danger">@formError</div> }

                <div class="sf-form-grid">
                    <div class="sf-form-group">
                        <label>Nombre *</label>
                        <input class="sf-input" @bind="form.Nombre" />
                    </div>
                    <div class="sf-form-group">
                        <label>Apellido *</label>
                        <input class="sf-input" @bind="form.Apellido" />
                    </div>
                    <div class="sf-form-group sf-form-group-full">
                        <label>Email *</label>
                        <input class="sf-input" type="email" @bind="form.Email"
                               disabled="@(editando != null)" />
                    </div>
                    <div class="sf-form-group">
                        <label>Teléfono</label>
                        <input class="sf-input" @bind="form.Telefono" />
                    </div>
                    <div class="sf-form-group">
                        <label>Rol *</label>
                        <select class="sf-select" @bind="form.RolId">
                            <option value="">— Selecciona —</option>
                            @foreach (var r in roles)
                            { <option value="@r.Id">@r.Nombre</option> }
                        </select>
                    </div>
                    <div class="sf-form-group sf-form-group-full">
                        <label>@(editando != null ? "Nueva contraseña (dejar vacío para no cambiar)" : "Contraseña *")</label>
                        <input class="sf-input" type="password" @bind="form.Password" />
                    </div>
                    @if (editando != null)
                    {
                        <div class="sf-form-group sf-form-group-full">
                            <label style="display:flex;align-items:center;gap:8px">
                                <input type="checkbox" @bind="form.Activo" /> Activo
                            </label>
                        </div>
                    }
                </div>
            </div>
            <div class="sf-modal-footer">
                <button class="sf-btn sf-btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="sf-btn sf-btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true, mostrarModal = false, guardando = false;
    private string? formError;
    private List<UsuarioItem> items = new();
    private List<RolItem> roles = new();
    private UsuarioItem? editando;
    private FormModel form = new();

    protected override async Task OnInitializedAsync()
    {
        var r = await Api.GetAsync<List<RolItem>>("api/v1/usuarios/roles");
        roles = r ?? new();
        await Cargar();
    }

    private async Task Cargar()
    {
        loading = true;
        var result = await Api.GetAsync<UsuariosResp>("api/v1/usuarios?porPagina=50");
        items = result?.Items ?? new();
        loading = false;
    }

    private void AbrirNuevo() { editando = null; form = new(); formError = null; mostrarModal = true; }

    private void AbrirEditar(UsuarioItem u)
    {
        editando = u;
        form = new FormModel
        {
            Nombre = u.Nombre ?? "", Apellido = u.Apellido ?? "",
            Email = u.Email ?? "", Telefono = u.Telefono,
            RolId = u.Rol?.Id.ToString() ?? "", Activo = u.Estado == "activo"
        };
        formError = null; mostrarModal = true;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Nombre) || string.IsNullOrWhiteSpace(form.Email) ||
            string.IsNullOrWhiteSpace(form.RolId))
        { formError = "Nombre, email y rol son obligatorios"; return; }

        guardando = true; formError = null;

        if (editando != null)
        {
            var r = await Api.PutAsync<object>($"api/v1/usuarios/{editando.Id}", new
            {
                nombre = form.Nombre, apellido = form.Apellido,
                telefono = form.Telefono, rol_id = Guid.Parse(form.RolId),
                activo = form.Activo,
                nuevo_password = string.IsNullOrWhiteSpace(form.Password) ? null : form.Password
            });
            if (!r.Success) { formError = r.Error; guardando = false; return; }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(form.Password))
            { formError = "La contraseña es obligatoria para nuevos usuarios"; guardando = false; return; }

            var r = await Api.PostAsync<object>("api/v1/usuarios", new
            {
                email = form.Email, password = form.Password,
                nombre = form.Nombre, apellido = form.Apellido,
                rol_id = Guid.Parse(form.RolId), telefono = form.Telefono
            });
            if (!r.Success) { formError = r.Error; guardando = false; return; }
        }

        CerrarModal(); await Cargar(); guardando = false;
    }

    private async Task Eliminar(Guid id)
    {
        await Api.DeleteAsync($"api/v1/usuarios/{id}");
        await Cargar();
    }

    private void CerrarModal() { mostrarModal = false; editando = null; form = new(); }

    private record UsuariosResp(int Total, List<UsuarioItem>? Items);
    private record UsuarioItem(Guid Id, string? Email, string? Nombre, string? Apellido,
        string? NombreCompleto, string? Telefono, string? Estado,
        RolItem? Rol, DateTimeOffset? UltimoAcceso);
    private record RolItem(Guid Id, string? Nombre, string? Codigo, string? Descripcion);

    private class FormModel
    {
        public string Nombre { get; set; } = "";
        public string Apellido { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Telefono { get; set; }
        public string RolId { get; set; } = "";
        public string? Password { get; set; }
        public bool Activo { get; set; } = true;
    }
}
