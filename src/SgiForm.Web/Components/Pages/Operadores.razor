@page "/operadores"
@layout SgiForm.Web.Components.Layout.MainLayout
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Operadores — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Operadores</h2>
        <span class="sf-text-muted">Gestión de operadores de campo</span>
    </div>
    <button class="sf-btn sf-btn-primary" @onclick="() => mostrarFormulario = true">
        + Nuevo operador
    </button>
</div>

<!-- FILTROS -->
<div class="sf-filter-bar">
    <input class="sf-input sf-input-sm" placeholder="Buscar nombre, código..."
           @bind="filtros.Buscar" @onkeyup="CargarOperadores" />
    <input class="sf-input sf-input-sm" placeholder="Zona"
           @bind="filtros.Zona" @onkeyup="CargarOperadores" />
    <select class="sf-select sf-select-sm" @onchange="OnActivoChange">
        <option value="">Todos</option>
        <option value="true">Activos</option>
        <option value="false">Inactivos</option>
    </select>
    <button class="sf-btn sf-btn-secondary sf-btn-sm" @onclick="CargarOperadores">Buscar</button>
</div>

<!-- TABLA -->
@if (loading)
{
    <div class="sf-loading-center"><div class="sf-spinner"></div></div>
}
else
{
    <div class="sf-card">
        <table class="sf-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Zona</th>
                    <th>Localidad</th>
                    <th>Estado</th>
                    <th>Última sync</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (operadores?.Items?.Any() == true)
                {
                    @foreach (var op in operadores.Items)
                    {
                        <tr>
                            <td><code>@op.CodigoOperador</code></td>
                            <td>@op.NombreCompleto</td>
                            <td>@(op.Email ?? "—")</td>
                            <td>@(op.Zona ?? "—")</td>
                            <td>@(op.Localidad ?? "—")</td>
                            <td>
                                @if (op.Activo)
                                {
                                    <span class="sf-badge sf-badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="sf-badge sf-badge-danger">Inactivo</span>
                                }
                            </td>
                            <td class="sf-text-xs sf-text-muted">
                                @(op.FechaUltimaSync.HasValue
                                    ? op.FechaUltimaSync.Value.ToString("dd/MM/yyyy HH:mm")
                                    : "Nunca")
                            </td>
                            <td>
                                <div class="sf-action-btns">
                                    <button class="sf-btn sf-btn-icon sf-btn-secondary"
                                            title="Editar" @onclick="() => EditarOperador(op)">
                                        &#9998;
                                    </button>
                                    <button class="sf-btn sf-btn-icon sf-btn-danger"
                                            title="Eliminar" @onclick="() => EliminarOperador(op.Id)">
                                        &#128465;
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="sf-text-center sf-text-muted">
                            No se encontraron operadores
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- PAGINACIÓN -->
    @if ((operadores?.Total ?? 0) > filtros.PorPagina)
    {
        <div class="sf-pagination">
            <button class="sf-btn sf-btn-secondary sf-btn-sm"
                    disabled="@(filtros.Pagina <= 1)"
                    @onclick="() => CambiarPagina(filtros.Pagina - 1)">
                &#8592; Anterior
            </button>
            <span>Página @filtros.Pagina de @TotalPaginas</span>
            <button class="sf-btn sf-btn-secondary sf-btn-sm"
                    disabled="@(filtros.Pagina >= TotalPaginas)"
                    @onclick="() => CambiarPagina(filtros.Pagina + 1)">
                Siguiente &#8594;
            </button>
        </div>
    }
}

<!-- MODAL FORMULARIO -->
@if (mostrarFormulario)
{
    <div class="sf-modal-overlay">
        <div class="sf-modal">
            <div class="sf-modal-header">
                <h3>@(operadorEditar?.Id != null ? "Editar operador" : "Nuevo operador")</h3>
                <button class="sf-btn-close" @onclick="CerrarFormulario">&#10005;</button>
            </div>
            <div class="sf-modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="sf-alert sf-alert-danger">@formError</div>
                }
                <EditForm Model="@formModel" OnValidSubmit="GuardarOperador">
                    <DataAnnotationsValidator />
                    <div class="sf-form-grid">
                        <div class="sf-form-group">
                            <label>Código *</label>
                            <InputText @bind-Value="formModel.CodigoOperador"
                                       class="sf-input" placeholder="OP001" />
                        </div>
                        <div class="sf-form-group">
                            <label>Nombre *</label>
                            <InputText @bind-Value="formModel.Nombre"
                                       class="sf-input" />
                        </div>
                        <div class="sf-form-group">
                            <label>Apellido *</label>
                            <InputText @bind-Value="formModel.Apellido"
                                       class="sf-input" />
                        </div>
                        <div class="sf-form-group">
                            <label>RUT</label>
                            <InputText @bind-Value="formModel.Rut" class="sf-input" />
                        </div>
                        <div class="sf-form-group">
                            <label>Email</label>
                            <InputText @bind-Value="formModel.Email" class="sf-input" type="email" />
                        </div>
                        <div class="sf-form-group">
                            <label>Teléfono</label>
                            <InputText @bind-Value="formModel.Telefono" class="sf-input" />
                        </div>
                        <div class="sf-form-group">
                            <label>Zona</label>
                            <InputText @bind-Value="formModel.Zona" class="sf-input" />
                        </div>
                        <div class="sf-form-group">
                            <label>Localidad</label>
                            <InputText @bind-Value="formModel.Localidad" class="sf-input" />
                        </div>
                        @if (operadorEditar == null)
                        {
                            <div class="sf-form-group sf-form-group-full">
                                <label>Contraseña *</label>
                                <InputText @bind-Value="formModel.Password"
                                           type="password" class="sf-input" />
                            </div>
                        }
                    </div>
                    <div class="sf-modal-footer">
                        <button type="button" class="sf-btn sf-btn-secondary"
                                @onclick="CerrarFormulario">Cancelar</button>
                        <button type="submit" class="sf-btn sf-btn-primary"
                                disabled="@guardando">
                            @(guardando ? "Guardando..." : "Guardar")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = false;
    private bool mostrarFormulario = false;
    private bool guardando = false;
    private string? formError;
    private OperadorListaResponse? operadores;
    private OperadorItem? operadorEditar;
    private OperadorFormModel formModel = new();
    private FiltrosModel filtros = new();

    private int TotalPaginas =>
        (int)Math.Ceiling((operadores?.Total ?? 0) / (double)filtros.PorPagina);

    protected override async Task OnInitializedAsync()
    {
        await CargarOperadores();
    }

    private async Task CargarOperadores()
    {
        loading = true;
        var url = $"api/v1/operadores?pagina={filtros.Pagina}&porPagina={filtros.PorPagina}";
        if (!string.IsNullOrWhiteSpace(filtros.Buscar)) url += $"&buscar={Uri.EscapeDataString(filtros.Buscar)}";
        if (!string.IsNullOrWhiteSpace(filtros.Zona)) url += $"&zona={Uri.EscapeDataString(filtros.Zona)}";
        if (filtros.Activo.HasValue) url += $"&activo={filtros.Activo.Value}";

        operadores = await Api.GetAsync<OperadorListaResponse>(url);
        loading = false;
    }

    private void OnActivoChange(ChangeEventArgs e)
    {
        filtros.Activo = e.Value?.ToString() switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };
    }

    private async Task CambiarPagina(int pagina)
    {
        filtros.Pagina = pagina;
        await CargarOperadores();
    }

    private void EditarOperador(OperadorItem op)
    {
        operadorEditar = op;
        formModel = new OperadorFormModel
        {
            CodigoOperador = op.CodigoOperador ?? "",
            Nombre = op.Nombre ?? "",
            Apellido = op.Apellido ?? "",
            Email = op.Email,
            Telefono = op.Telefono,
            Zona = op.Zona,
            Localidad = op.Localidad
        };
        mostrarFormulario = true;
    }

    private async Task GuardarOperador()
    {
        guardando = true;
        formError = null;

        ApiResult<object> result;
        if (operadorEditar != null)
            result = await Api.PutAsync<object>($"api/v1/operadores/{operadorEditar.Id}", formModel);
        else
            result = await Api.PostAsync<object>("api/v1/operadores", formModel);

        if (result.Success)
        {
            CerrarFormulario();
            await CargarOperadores();
        }
        else
        {
            formError = result.Error;
        }
        guardando = false;
    }

    private async Task EliminarOperador(Guid id)
    {
        var result = await Api.DeleteAsync($"api/v1/operadores/{id}");
        if (result.Success) await CargarOperadores();
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        operadorEditar = null;
        formModel = new();
        formError = null;
    }

    // DTOs
    private record OperadorListaResponse(int Total, int Pagina, int PorPagina, List<OperadorItem>? Items);
    private record OperadorItem(
        Guid Id, string? CodigoOperador, string? NombreCompleto, string? Nombre, string? Apellido,
        string? Email, string? Telefono, string? Zona, string? Localidad,
        bool Activo, DateTimeOffset? FechaUltimaSync);

    private class FiltrosModel
    {
        public string? Buscar { get; set; }
        public string? Zona { get; set; }
        public bool? Activo { get; set; }
        public int Pagina { get; set; } = 1;
        public int PorPagina { get; set; } = 25;
    }

    private class OperadorFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string CodigoOperador { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required]
        public string Nombre { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required]
        public string Apellido { get; set; } = "";
        public string? Rut { get; set; }
        public string? Email { get; set; }
        public string? Telefono { get; set; }
        public string? Zona { get; set; }
        public string? Localidad { get; set; }
        public string? Password { get; set; }
    }
}
