@page "/reportes"
@layout SgiForm.Web.Components.Layout.MainLayout
@inject ApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Reportes — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Reportes</h2>
        <span class="sf-text-muted">Exporta datos a Excel y consulta reportes consolidados</span>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px">

    <!-- Card: Exportar Excel -->
    <div class="sf-card" style="padding:24px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
            <div style="font-size:32px">📊</div>
            <div>
                <h3 style="font-size:16px;font-weight:700;margin:0">Exportar a Excel</h3>
                <p class="sf-text-muted" style="font-size:13px;margin:0">
                    Descarga un Excel con todas las asignaciones e inspecciones
                </p>
            </div>
        </div>

        <div class="sf-form-grid" style="margin-bottom:12px">
            <div class="sf-form-group">
                <label>Estado</label>
                <select class="sf-select sf-select-sm" @bind="excelFiltros.Estado">
                    <option value="">Todos</option>
                    <option value="pendiente">Pendiente</option>
                    <option value="finalizada">Finalizada</option>
                    <option value="sincronizada">Sincronizada</option>
                </select>
            </div>
            <div class="sf-form-group">
                <label>Operador</label>
                <select class="sf-select sf-select-sm" @bind="excelFiltros.OperadorId">
                    <option value="">Todos</option>
                    @foreach (var op in operadores)
                    { <option value="@op.Id">@op.NombreCompleto</option> }
                </select>
            </div>
            <div class="sf-form-group">
                <label>Localidad</label>
                <input class="sf-input sf-input-sm" @bind="excelFiltros.Localidad" placeholder="La Serena" />
            </div>
            <div class="sf-form-group">
                <label>Ruta</label>
                <input class="sf-input sf-input-sm" @bind="excelFiltros.Ruta" placeholder="R01" />
            </div>
        </div>

        <button class="sf-btn sf-btn-primary" @onclick="DescargarExcel" disabled="@descargando">
            @(descargando ? "Generando..." : "⬇️ Descargar Excel")
        </button>
    </div>

    <!-- Card: Estadísticas rápidas -->
    <div class="sf-card" style="padding:24px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
            <div style="font-size:32px">📈</div>
            <div>
                <h3 style="font-size:16px;font-weight:700;margin:0">Resumen rápido</h3>
                <p class="sf-text-muted" style="font-size:13px;margin:0">
                    KPIs actualizados en tiempo real
                </p>
            </div>
        </div>

        @if (dashboard != null)
        {
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
                <div style="padding:12px;background:#f0f9ff;border-radius:6px;text-align:center">
                    <div style="font-size:24px;font-weight:800">@dashboard.TotalServicios</div>
                    <div class="sf-text-xs sf-text-muted">Servicios</div>
                </div>
                <div style="padding:12px;background:#f0fdf4;border-radius:6px;text-align:center">
                    <div style="font-size:24px;font-weight:800">@dashboard.OperadoresActivos</div>
                    <div class="sf-text-xs sf-text-muted">Operadores</div>
                </div>
                <div style="padding:12px;background:#fefce8;border-radius:6px;text-align:center">
                    <div style="font-size:24px;font-weight:800">@GetAsignacionCount("pendiente")</div>
                    <div class="sf-text-xs sf-text-muted">Pendientes</div>
                </div>
                <div style="padding:12px;background:#ecfdf5;border-radius:6px;text-align:center">
                    <div style="font-size:24px;font-weight:800">@GetAsignacionCount("finalizada")</div>
                    <div class="sf-text-xs sf-text-muted">Finalizadas</div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Reporte por operador -->
<div class="sf-card" style="margin-bottom:16px">
    <div class="sf-card-header">
        <h3>Productividad por operador</h3>
    </div>
    @if (reporteOperadores != null)
    {
        <table class="sf-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Operador</th>
                    <th>Zona</th>
                    <th class="sf-text-center">Pendientes</th>
                    <th class="sf-text-center">En ejecución</th>
                    <th class="sf-text-center">Finalizadas</th>
                    <th class="sf-text-center">Sincronizadas</th>
                    <th class="sf-text-center">Total</th>
                    <th>Última sync</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var op in reporteOperadores)
                {
                    <tr>
                        <td><code>@op.CodigoOperador</code></td>
                        <td><strong>@op.Nombre</strong></td>
                        <td class="sf-text-muted">@(op.Zona ?? "—")</td>
                        <td class="sf-text-center"><span class="sf-badge sf-badge-warning">@op.Pendientes</span></td>
                        <td class="sf-text-center"><span class="sf-badge sf-badge-info">@op.EnEjecucion</span></td>
                        <td class="sf-text-center"><span class="sf-badge sf-badge-success">@op.Finalizadas</span></td>
                        <td class="sf-text-center"><span class="sf-badge sf-badge-success">@op.Sincronizadas</span></td>
                        <td class="sf-text-center"><strong>@op.Total</strong></td>
                        <td class="sf-text-xs sf-text-muted">
                            @(op.FechaUltimaSync.HasValue ? op.FechaUltimaSync.Value.ToLocalTime().ToString("dd/MM HH:mm") : "Nunca")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Reporte por localidad -->
<div class="sf-card">
    <div class="sf-card-header">
        <h3>Avance por localidad / ruta / lote</h3>
    </div>
    @if (reporteLocalidad != null)
    {
        <table class="sf-table sf-table-sm">
            <thead>
                <tr>
                    <th>Localidad</th>
                    <th>Ruta</th>
                    <th>Lote</th>
                    <th class="sf-text-right">Total</th>
                    <th class="sf-text-right">Asignados</th>
                    <th class="sf-text-right">Sin asignar</th>
                    <th>Avance</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in reporteLocalidad)
                {
                    var pct = r.TotalServicios > 0 ? (int)((double)r.ConAsignacion / r.TotalServicios * 100) : 0;
                    <tr>
                        <td>@r.Localidad</td>
                        <td>@r.Ruta</td>
                        <td>@r.Lote</td>
                        <td class="sf-text-right">@r.TotalServicios</td>
                        <td class="sf-text-right sf-text-success">@r.ConAsignacion</td>
                        <td class="sf-text-right @(r.SinAsignar > 0 ? "sf-text-danger" : "")">@r.SinAsignar</td>
                        <td style="min-width:100px">
                            <div style="display:flex;align-items:center;gap:4px">
                                <div class="sf-progress" style="flex:1">
                                    <div class="sf-progress-bar" style="width:@pct%"></div>
                                </div>
                                <span class="sf-text-xs">@pct%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private bool descargando = false;
    private DashboardData? dashboard;
    private List<OpReport>? reporteOperadores;
    private List<LocReport>? reporteLocalidad;
    private List<OperadorRef> operadores = new();
    private ExcelFiltros excelFiltros = new();

    protected override async Task OnInitializedAsync()
    {
        var tasks = new List<Task>
        {
            Task.Run(async () => dashboard = await Api.GetAsync<DashboardData>("api/v1/dashboard/resumen")),
            Task.Run(async () => reporteOperadores = await Api.GetAsync<List<OpReport>>("api/v1/reportes/por-operador")),
            Task.Run(async () => reporteLocalidad = await Api.GetAsync<List<LocReport>>("api/v1/reportes/por-localidad")),
            Task.Run(async () => {
                var r = await Api.GetAsync<OperadoresResp>("api/v1/operadores?porPagina=100");
                operadores = r?.Items ?? new();
            })
        };
        await Task.WhenAll(tasks);
    }

    private void DescargarExcel()
    {
        descargando = true;
        var q = "api/v1/reportes/excel?";
        if (!string.IsNullOrEmpty(excelFiltros.Estado)) q += $"estado={excelFiltros.Estado}&";
        if (!string.IsNullOrEmpty(excelFiltros.OperadorId)) q += $"operadorId={excelFiltros.OperadorId}&";
        if (!string.IsNullOrEmpty(excelFiltros.Localidad)) q += $"localidad={Uri.EscapeDataString(excelFiltros.Localidad)}&";
        if (!string.IsNullOrEmpty(excelFiltros.Ruta)) q += $"ruta={Uri.EscapeDataString(excelFiltros.Ruta)}&";

        // Abrir en nueva pestaña con token en URL (alternativa simple)
        var url = $"http://localhost:5043/{q.TrimEnd('&')}";
        Nav.NavigateTo(url, forceLoad: true);
        descargando = false;
    }

    private int GetAsignacionCount(string estado) =>
        dashboard?.Asignaciones?.FirstOrDefault(a => a.Estado == estado)?.Total ?? 0;

    private record DashboardData(int TotalServicios, List<EstadoCount>? Asignaciones,
        int? TotalFotografias, int? OperadoresActivos);
    private record EstadoCount(string? Estado, int Total);
    private record OpReport(string? CodigoOperador, string? Nombre, string? Zona,
        int Pendientes, int EnEjecucion, int Finalizadas, int Sincronizadas,
        int Total, DateTimeOffset? FechaUltimaSync);
    private record LocReport(string? Localidad, string? Ruta, string? Lote,
        int TotalServicios, int ConAsignacion, int SinAsignar);
    private record OperadorRef(Guid Id, string? NombreCompleto);
    private record OperadoresResp(int Total, List<OperadorRef>? Items);

    private class ExcelFiltros
    {
        public string? Estado { get; set; }
        public string? OperadorId { get; set; }
        public string? Localidad { get; set; }
        public string? Ruta { get; set; }
    }
}
