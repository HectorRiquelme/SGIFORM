@page "/tipos-inspeccion"
@layout SgiForm.Web.Components.Layout.MainLayout
@inject ApiClient Api

<PageTitle>Tipos de Inspección — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Tipos de Inspección</h2>
        <span class="sf-text-muted">Define las categorías de inspección disponibles</span>
    </div>
    <button class="sf-btn sf-btn-primary" @onclick="AbrirNuevo">+ Nuevo tipo</button>
</div>

@if (loading)
{
    <div class="sf-loading-center"><div class="sf-spinner"></div></div>
}
else
{
    <div class="sf-card">
        <table class="sf-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    @foreach (var t in items)
                    {
                        <tr>
                            <td><code>@t.Codigo</code></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    @if (!string.IsNullOrEmpty(t.Icono))
                                    {
                                        <span>@t.Icono</span>
                                    }
                                    <strong>@t.Nombre</strong>
                                </div>
                            </td>
                            <td class="sf-text-muted">@(t.Descripcion ?? "—")</td>
                            <td>
                                @if (t.Activo)
                                {
                                    <span class="sf-badge sf-badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="sf-badge sf-badge-danger">Inactivo</span>
                                }
                            </td>
                            <td>
                                <div class="sf-action-btns">
                                    <button class="sf-btn sf-btn-secondary sf-btn-sm"
                                            @onclick="() => AbrirEditar(t)">Editar</button>
                                    <button class="sf-btn sf-btn-danger sf-btn-sm"
                                            @onclick="() => Eliminar(t.Id)">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="sf-text-center sf-text-muted" style="padding:32px">
                            No hay tipos de inspección creados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (!string.IsNullOrEmpty(mensajeExito))
{
    <div class="sf-alert sf-alert-success" style="margin-top:12px">@mensajeExito</div>
}

<!-- MODAL -->
@if (mostrarModal)
{
    <div class="sf-modal-overlay">
        <div class="sf-modal">
            <div class="sf-modal-header">
                <h3>@(editando != null ? "Editar tipo" : "Nuevo tipo de inspección")</h3>
                <button class="sf-btn-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="sf-modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="sf-alert sf-alert-danger">@formError</div>
                }
                <div class="sf-form-grid">
                    <div class="sf-form-group">
                        <label>Código *</label>
                        <input class="sf-input" @bind="form.Codigo"
                               placeholder="INSP-MED" disabled="@(editando != null)" />
                    </div>
                    <div class="sf-form-group">
                        <label>Nombre *</label>
                        <input class="sf-input" @bind="form.Nombre"
                               placeholder="Inspección de Medidor" />
                    </div>
                    <div class="sf-form-group sf-form-group-full">
                        <label>Descripción</label>
                        <textarea class="sf-input" @bind="form.Descripcion" rows="2"
                                  placeholder="Descripción detallada del tipo de inspección"></textarea>
                    </div>
                    <div class="sf-form-group">
                        <label>Ícono (emoji)</label>
                        <input class="sf-input" @bind="form.Icono" placeholder="🔧" maxlength="4" />
                    </div>
                    <div class="sf-form-group">
                        <label>Color (hex)</label>
                        <input class="sf-input" @bind="form.Color" placeholder="#1a56db" maxlength="7" />
                    </div>
                    @if (editando != null)
                    {
                        <div class="sf-form-group sf-form-group-full">
                            <label style="display:flex;align-items:center;gap:8px">
                                <input type="checkbox" @bind="form.Activo" />
                                Activo
                            </label>
                        </div>
                    }
                </div>
            </div>
            <div class="sf-modal-footer">
                <button class="sf-btn sf-btn-secondary" @onclick="CerrarModal">Cancelar</button>
                <button class="sf-btn sf-btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private string? formError;
    private string? mensajeExito;
    private List<TipoItem> items = new();
    private TipoItem? editando;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        loading = true;
        var result = await Api.GetAsync<List<TipoItem>>("api/v1/tipos-inspeccion");
        items = result ?? new();
        loading = false;
    }

    private void AbrirNuevo()
    {
        editando = null;
        form = new();
        formError = null;
        mostrarModal = true;
    }

    private void AbrirEditar(TipoItem t)
    {
        editando = t;
        form = new FormModel
        {
            Codigo = t.Codigo ?? "", Nombre = t.Nombre ?? "",
            Descripcion = t.Descripcion, Activo = t.Activo,
            Icono = t.Icono, Color = t.Color
        };
        formError = null;
        mostrarModal = true;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Codigo) || string.IsNullOrWhiteSpace(form.Nombre))
        {
            formError = "Código y Nombre son obligatorios";
            return;
        }

        guardando = true;
        formError = null;

        ApiResult<object> result;
        if (editando != null)
            result = await Api.PutAsync<object>($"api/v1/tipos-inspeccion/{editando.Id}", form);
        else
            result = await Api.PostAsync<object>("api/v1/tipos-inspeccion", form);

        if (result.Success)
        {
            mensajeExito = editando != null ? "Tipo actualizado correctamente" : "Tipo creado correctamente";
            CerrarModal();
            await Cargar();
            _ = Task.Delay(3000).ContinueWith(_ => { mensajeExito = null; InvokeAsync(StateHasChanged); });
        }
        else
        {
            formError = result.Error;
        }
        guardando = false;
    }

    private async Task Eliminar(Guid id)
    {
        var r = await Api.DeleteAsync($"api/v1/tipos-inspeccion/{id}");
        if (r.Success) await Cargar();
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        editando = null;
        form = new();
    }

    private record TipoItem(
        Guid Id, string? Codigo, string? Nombre, string? Descripcion,
        bool Activo, string? Icono, string? Color);

    private class FormModel
    {
        public string Codigo { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Descripcion { get; set; }
        public bool Activo { get; set; } = true;
        public string? Icono { get; set; }
        public string? Color { get; set; }
    }
}
