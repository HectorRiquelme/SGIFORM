@page "/versionamiento"
@layout SgiForm.Web.Components.Layout.MainLayout
@inject ReleaseNotesService ReleaseNotes

<PageTitle>Versionamiento — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Versionamiento</h2>
        <span class="sf-text-muted">Notas locales de versiones desplegadas</span>
    </div>
    <span class="sf-badge sf-badge-info">v@documento.CurrentVersion</span>
</div>

<div class="sf-card">
    <div class="sf-card-header">
        <h3>Notas de versión</h3>
        <button class="sf-btn sf-btn-primary sf-btn-sm" @onclick="ToggleNotas">
            @(mostrarNotas ? "Ocultar notas" : "Ver notas de versión")
        </button>
    </div>

    <div class="sf-modal-body">
        @if (loading)
        {
            <div class="sf-loading-inline"><span class="sf-spinner-sm"></span> Cargando notas...</div>
        }
        else if (!mostrarNotas)
        {
            <p class="sf-text-muted">Haz clic en "Ver notas de versión" para revisar el historial local.</p>
        }
        else if (documento.Notes.Count == 0)
        {
            <div class="sf-alert sf-alert-warning">No hay notas de versión disponibles.</div>
        }
        else
        {
            @foreach (var nota in documento.Notes.OrderByDescending(n => n.Date))
            {
                <div style="padding:14px 0;border-bottom:1px solid var(--sf-border)">
                    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
                        <strong>@nota.Title</strong>
                        <span class="sf-badge sf-badge-secondary">v@nota.Version</span>
                    </div>
                    <div class="sf-text-xs sf-text-muted" style="margin-top:2px">@nota.Date</div>
                    <ul style="margin:8px 0 0 20px">
                        @foreach (var cambio in nota.Changes)
                        {
                            <li>@cambio</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>

@code {
    private bool loading = true;
    private bool mostrarNotas;
    private ReleaseNotesDocument documento = ReleaseNotesDocument.Empty;

    protected override async Task OnInitializedAsync()
    {
        documento = await ReleaseNotes.GetAsync();
        loading = false;
    }

    private void ToggleNotas() => mostrarNotas = !mostrarNotas;
}
