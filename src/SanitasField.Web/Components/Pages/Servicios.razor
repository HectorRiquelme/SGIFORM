@page "/servicios"
@layout SanitasField.Web.Components.Layout.MainLayout
@inject ApiClient Api

<PageTitle>Servicios — SGI-FORM</PageTitle>

<div class="sf-page-header">
    <div>
        <h2>Servicios de Inspección</h2>
        <span class="sf-text-muted">Registros importados desde Excel listos para asignar</span>
    </div>
    <a href="/importaciones" class="sf-btn sf-btn-primary">+ Importar Excel</a>
</div>

<!-- Filtros -->
<div class="sf-filter-bar">
    <input class="sf-input sf-input-sm" placeholder="Buscar por dirección, servicio, nombre..."
           @bind="filtros.Buscar" @bind:event="oninput" @onkeyup="OnBuscar" style="min-width:220px" />
    <input class="sf-input sf-input-sm" placeholder="Localidad" @bind="filtros.Localidad" />
    <input class="sf-input sf-input-sm" placeholder="Ruta" @bind="filtros.Ruta" />
    <input class="sf-input sf-input-sm" placeholder="Lote" @bind="filtros.Lote" />
    <select class="sf-select sf-select-sm" @bind="filtros.ConAsignacion">
        <option value="">Todos</option>
        <option value="true">Con asignación</option>
        <option value="false">Sin asignar</option>
    </select>
    <button class="sf-btn sf-btn-secondary sf-btn-sm" @onclick="Cargar">Buscar</button>
</div>

@if (loading)
{
    <div class="sf-loading-center"><div class="sf-spinner"></div></div>
}
else
{
    <div class="sf-card">
        <div class="sf-card-header">
            <span class="sf-text-muted" style="font-size:13px">
                @total registros encontrados
            </span>
        </div>
        <table class="sf-table">
            <thead>
                <tr>
                    <th>ID Servicio</th>
                    <th>Medidor</th>
                    <th>Cliente</th>
                    <th>Dirección</th>
                    <th>Localidad</th>
                    <th>Ruta</th>
                    <th>Asignado</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    @foreach (var s in items)
                    {
                        <tr>
                            <td><code style="font-size:12px">@s.IdServicio</code></td>
                            <td>
                                <div style="font-size:13px">@(s.NumeroMedidor ?? "—")</div>
                                <div class="sf-text-muted sf-text-xs">@(s.Marca ?? "") @(s.Diametro ?? "")</div>
                            </td>
                            <td>@(s.NombreCliente ?? "—")</td>
                            <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                title="@s.Direccion">
                                @(s.Direccion ?? "—")
                            </td>
                            <td>@(s.Localidad ?? "—")</td>
                            <td>@(s.Ruta ?? "—")</td>
                            <td>
                                @if (s.TieneAsignacion)
                                {
                                    <span class="sf-badge sf-badge-success">Asignado</span>
                                }
                                else
                                {
                                    <span class="sf-badge sf-badge-secondary">Libre</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="sf-text-center sf-text-muted" style="padding:32px">
                            No hay servicios. <a href="/importaciones">Importa un Excel</a> para comenzar.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (total > filtros.PorPagina)
    {
        <div class="sf-pagination">
            <button class="sf-btn sf-btn-secondary sf-btn-sm"
                    disabled="@(filtros.Pagina <= 1)"
                    @onclick="() => CambiarPagina(filtros.Pagina - 1)">← Anterior</button>
            <span>Página @filtros.Pagina de @((int)Math.Ceiling((double)total / filtros.PorPagina))</span>
            <button class="sf-btn sf-btn-secondary sf-btn-sm"
                    disabled="@(filtros.Pagina * filtros.PorPagina >= total)"
                    @onclick="() => CambiarPagina(filtros.Pagina + 1)">Siguiente →</button>
        </div>
    }
}

@code {
    private bool loading = true;
    private int total = 0;
    private List<ServicioItem> items = new();
    private FiltrosModel filtros = new();
    private System.Timers.Timer? debounce;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        loading = true;
        var q = $"api/v1/servicios?pagina={filtros.Pagina}&porPagina={filtros.PorPagina}";
        if (!string.IsNullOrWhiteSpace(filtros.Buscar)) q += $"&q={Uri.EscapeDataString(filtros.Buscar)}";
        if (!string.IsNullOrWhiteSpace(filtros.Localidad)) q += $"&localidad={Uri.EscapeDataString(filtros.Localidad)}";
        if (!string.IsNullOrWhiteSpace(filtros.Ruta)) q += $"&ruta={Uri.EscapeDataString(filtros.Ruta)}";
        if (!string.IsNullOrWhiteSpace(filtros.Lote)) q += $"&lote={Uri.EscapeDataString(filtros.Lote)}";

        var result = await Api.GetAsync<ServiciosResponse>(q);
        items = result?.Items ?? new();
        total = result?.Total ?? 0;
        loading = false;
    }

    private void OnBuscar()
    {
        debounce?.Dispose();
        debounce = new System.Timers.Timer(400);
        debounce.Elapsed += async (_, _) => { debounce?.Dispose(); await InvokeAsync(Cargar); };
        debounce.Start();
    }

    private async Task CambiarPagina(int p) { filtros.Pagina = p; await Cargar(); }

    private record ServiciosResponse(int Total, List<ServicioItem>? Items);
    private record ServicioItem(
        Guid Id, string? IdServicio, string? NumeroMedidor, string? Marca,
        string? Diametro, string? Direccion, string? NombreCliente,
        string? Localidad, string? Ruta, string? Lote, bool TieneAsignacion);

    private class FiltrosModel
    {
        public string? Buscar { get; set; }
        public string? Localidad { get; set; }
        public string? Ruta { get; set; }
        public string? Lote { get; set; }
        public string? ConAsignacion { get; set; }
        public int Pagina { get; set; } = 1;
        public int PorPagina { get; set; } = 30;
    }
}
