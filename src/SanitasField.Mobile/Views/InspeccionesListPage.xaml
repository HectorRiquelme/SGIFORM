<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SanitasField.Mobile.ViewModels"
             xmlns:models="clr-namespace:SanitasField.Mobile.Models"
             x:Class="SanitasField.Mobile.Views.InspeccionesListPage"
             x:DataType="vm:InspeccionesListViewModel"
             Title="Mis Inspecciones">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,8,0">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="SGI-FORM" FontSize="16" FontAttributes="Bold" TextColor="White" />
                <Label Text="{Binding NombreOperador}" FontSize="11" TextColor="#bfdbfe" />
            </VerticalStackLayout>
            <!-- Indicador de sync -->
            <Frame Grid.Column="1"
                   BackgroundColor="{Binding TieneConexion, Converter={StaticResource BoolToColorConverter}}"
                   CornerRadius="12" Padding="6,3">
                <Label Text="{Binding TieneConexion, Converter={StaticResource BoolToConexionConverter}}"
                       TextColor="White" FontSize="11" />
            </Frame>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Estadísticas -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*"
              BackgroundColor="#1a56db" Padding="8">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label Text="{Binding Estadisticas.TotalAsignaciones}"
                       TextColor="White" FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Total" TextColor="#bfdbfe" FontSize="10"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="{Binding Estadisticas.Pendientes}"
                       TextColor="#fbbf24" FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Pendientes" TextColor="#bfdbfe" FontSize="10"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <Label Text="{Binding Estadisticas.EnEjecucion}"
                       TextColor="#34d399" FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="En curso" TextColor="#bfdbfe" FontSize="10"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                <Label Text="{Binding Estadisticas.Completadas}"
                       TextColor="#6ee7b7" FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Completadas" TextColor="#bfdbfe" FontSize="10"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Barra de sincronización -->
        <Frame Grid.Row="1"
               IsVisible="{Binding MensajeSync, Converter={StaticResource StringNotNullConverter}}"
               BackgroundColor="#eff6ff" Padding="10,6" Margin="8,4" CornerRadius="6">
            <Label Text="{Binding MensajeSync}" FontSize="12" TextColor="#1e40af" />
        </Frame>

        <!-- Búsqueda y filtros -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="8,6" ColumnSpacing="8">
            <SearchBar Grid.Column="0"
                       Text="{Binding TextoBusqueda}"
                       Placeholder="Buscar por dirección, servicio..."
                       BackgroundColor="#f9fafb" />
            <Picker Grid.Column="1" WidthRequest="120"
                    SelectedItem="{Binding FiltroEstado}"
                    BackgroundColor="#f9fafb">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>todas</x:String>
                        <x:String>pendiente</x:String>
                        <x:String>en_ejecucion</x:String>
                        <x:String>finalizada</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Grid>

        <!-- Lista de inspecciones -->
        <RefreshView Grid.Row="3"
                     Command="{Binding CargarCommand}"
                     IsRefreshing="{Binding Cargando}">
            <CollectionView ItemsSource="{Binding AsignacionesFiltradas}"
                            EmptyView="No hay inspecciones disponibles">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AsignacionLocal">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Ver mapa" BackgroundColor="#3b82f6"
                                               IconImageSource="map.png" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame Margin="8,4" CornerRadius="8" Padding="12" HasShadow="True"
                                   BackgroundColor="White">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InspeccionesListViewModel}}, Path=AbrirInspeccionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                                    <!-- ID Servicio -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding IdServicio}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#111827" />

                                    <!-- Badge estado -->
                                    <Frame Grid.Row="0" Grid.Column="1"
                                           CornerRadius="10" Padding="8,3"
                                           BackgroundColor="{Binding Estado, Converter={StaticResource EstadoColorConverter}}">
                                        <Label Text="{Binding Estado}"
                                               TextColor="White" FontSize="11" />
                                    </Frame>

                                    <!-- Dirección -->
                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding Direccion}"
                                           FontSize="13" TextColor="#6b7280"
                                           LineBreakMode="TailTruncation" />

                                    <!-- Detalles -->
                                    <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                                           Spacing="12" Margin="0,4,0,0">
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="&#x1F4CD;" FontSize="11" />
                                            <Label Text="{Binding Localidad}"
                                                   FontSize="11" TextColor="#9ca3af" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="&#x1F6E3;" FontSize="11" />
                                            <Label Text="{Binding Ruta}"
                                                   FontSize="11" TextColor="#9ca3af" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="&#x1F4CF;" FontSize="11" />
                                            <Label Text="{Binding NumeroMedidor}"
                                                   FontSize="11" TextColor="#9ca3af" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>

                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Botón de sincronización manual -->
        <Button Grid.Row="4"
                Text="{Binding Sincronizando, Converter={StaticResource BoolToSyncTextConverter}}"
                Command="{Binding SincronizarCommand}"
                IsEnabled="{Binding Sincronizando, Converter={StaticResource InvertBoolConverter}}"
                BackgroundColor="#1a56db"
                TextColor="White"
                Margin="8" CornerRadius="8"
                HeightRequest="48">
            <Button.ImageSource>
                <FontImageSource Glyph="&#x1F504;" FontFamily="OpenSansRegular"
                                 Color="White" Size="16" />
            </Button.ImageSource>
        </Button>

    </Grid>
</ContentPage>
