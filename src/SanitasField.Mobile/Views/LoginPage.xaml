<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SanitasField.Mobile.ViewModels"
             x:Class="SanitasField.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1a56db">

    <ScrollView>
        <VerticalStackLayout Padding="32" VerticalOptions="Center" Spacing="16">

            <!-- Logo / Título -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,40,0,24">
                <HorizontalStackLayout HorizontalOptions="Center">
                    <Label Text="SGI" FontSize="32" FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="-FORM" FontSize="32"
                           TextColor="#93c5fd" />
                </HorizontalStackLayout>
                <Label Text="Gesti&#243;n inteligente de inspecciones en terreno"
                       FontSize="12" TextColor="#93c5fd"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Card de login -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="24" HasShadow="True">
                <VerticalStackLayout Spacing="12">

                    <!-- Error -->
                    <Frame IsVisible="{Binding ErrorMsg, Converter={StaticResource StringNotNullConverter}}"
                           BackgroundColor="#fee2e2" BorderColor="#fecaca"
                           CornerRadius="6" Padding="10">
                        <Label Text="{Binding ErrorMsg}"
                               TextColor="#991b1b" FontSize="13" />
                    </Frame>

                    <!-- Código operador -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Código de operador" FontSize="13" TextColor="#6b7280" />
                        <Entry Text="{Binding CodigoOperador}"
                               Placeholder="OP001"
                               BackgroundColor="#f9fafb"
                               TextColor="#111827" />
                    </VerticalStackLayout>

                    <!-- Empresa -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Empresa (slug)" FontSize="13" TextColor="#6b7280" />
                        <Entry Text="{Binding EmpresaSlug}"
                               Placeholder="sanitaria-demo"
                               BackgroundColor="#f9fafb"
                               TextColor="#111827" />
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Contraseña" FontSize="13" TextColor="#6b7280" />
                        <Entry Text="{Binding Password}"
                               IsPassword="True"
                               Placeholder="••••••••"
                               BackgroundColor="#f9fafb"
                               TextColor="#111827" />
                    </VerticalStackLayout>

                    <!-- Botón login -->
                    <Button Text="{Binding IniciandoSesion, Converter={StaticResource BoolToLoginTextConverter}}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IniciandoSesion, Converter={StaticResource InvertBoolConverter}}"
                            BackgroundColor="#1a56db"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="48"
                            Margin="0,8,0,0" />

                    <!-- Config avanzada -->
                    <Label Text="Configuración avanzada"
                           TextColor="#3b82f6" FontSize="12"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleConfigAvanzadaCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                    <VerticalStackLayout IsVisible="{Binding MostrarConfigAvanzada}" Spacing="4">
                        <Label Text="URL de la API" FontSize="13" TextColor="#6b7280" />
                        <Entry Text="{Binding ApiUrl}"
                               Placeholder="https://api.sgi-form.cl"
                               BackgroundColor="#f9fafb" FontSize="12" />

                        <Button Text="Ver notas de versión"
                                Command="{Binding VerNotasVersionCommand}"
                                BackgroundColor="#ffffff"
                                BorderColor="#d1d5db"
                                BorderWidth="1"
                                TextColor="#1f2937"
                                CornerRadius="8"
                                HeightRequest="40"
                                Margin="0,8,0,0" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Label Text="v1.0.0 — SGI-FORM"
                   TextColor="#93c5fd" FontSize="11"
                   HorizontalOptions="Center" Margin="0,8,0,40" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
